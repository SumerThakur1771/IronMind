# PostgreSQL connection string (use the Supabase pooler URL for serverless)
DATABASE_URL=

# Google Gemini API key — used to generate embeddings
GEMINI_API_KEY=

# OpenRouter API key — used to generate chat responses
OPENROUTER_API_KEY=

# Secret used to sign and verify authentication tokens (use a 64+ char random string)
JWT_SECRET=

# Invite code required to register a new account. Registration is closed if unset.
INVITE_CODE=
