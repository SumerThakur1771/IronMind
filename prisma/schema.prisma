generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Knowledge {
  id        Int       @id @default(autoincrement())
  title     String
  category  String
  content   String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("knowledge")
}
